    {
      "parameters": {
        "fromEmail": "your-bot@example.com",
        "toEmail": "={{$json.email}}",
        "subject": "=🚨 Action Required: New {{$json.rating}}★ Review for {{$json.business_name}}",
        "html": "=<html>\n<body style=\"font-family: Arial, sans-serif;\">\n\n<h2>🚨 Negative Review Alert</h2>\n\n<p>Hello <b>{{$json.owner_name}}</b>,</p>\n\n<p>A new negative review has been detected for your business.</p>\n\n<hr>\n\n<p><b>Business:</b> {{$json.business_name}}</p>\n\n<p><b>Customer:</b> {{$json.customer_name}}</p>\n\n<p><b>Rating:</b> {{$json.rating}} ⭐</p>\n\n<p><b>Review Date:</b> {{$json.review_date}}</p>\n\n<p><b>Customer Review:</b></p>\n\n<div style=\"background:#f5f5f5;padding:10px;border-left:4px solid red;\">\n{{$json.review_text}}\n</div>\n\n<br>\n\n<p><b>AI Suggested Reply:</b></p>\n\n<div style=\"background:#eef7ee;padding:10px;border-left:4px solid green;\">\n{{ JSON.parse($json.output).review_reply }}\n</div>\n\n<hr>\n\n<p>\nPlease review the suggested response before posting it publicly on Google Reviews.\n</p>\n\n<p>\nRegards,<br>\n<b>ReviewGuard AI</b><br>\nyour-bot@example.com\n</p>\n\n</body>\n</html>",
